# Copy to .env.local and fill in. See docs/SUPABASE-SETUP.md.
NEXT_PUBLIC_SUPABASE_URL=https://fjfoizybwbsjwzcnuaar.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_fwDD5GndHv8JTQ-LiiYT6w_8J_iaM_I

# Server-only. From Supabase dashboard → Project Settings → API. NEVER commit the real value.
SUPABASE_SERVICE_ROLE_KEY=

# --- Media storage (S3-compatible: MinIO in dev, Cloudflare R2 in prod) ---
# Dev: reuse a local MinIO with ports published to the host → use localhost, not the
# Docker-internal hostname (the browser does presigned uploads directly).
AWS_ENDPOINT=http://localhost:9000
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

# --- Video pipeline ---
# Generate: openssl rand -hex 32
PLAYBACK_TOKEN_SECRET=
TRANSCODE_CALLBACK_SECRET=
# pg-boss → Postgres. Supabase → Project Settings → Database → Connection string (URI).
# Use the SESSION POOLER (aws-1-<region>.pooler.supabase.com:5432) — the direct
# db.<ref>.supabase.co host drops the worker's long-lived connection. NOT the txn pooler (6543).
DATABASE_URL=

# Internal URL the transcode worker calls back to (default http://localhost:3000)
APP_INTERNAL_URL=http://localhost:3000

# --- Certificates ---
# Public app origin printed on the certificate + encoded in its QR (verify URL).
# Default http://localhost:3000 in dev; set to the real domain in prod.
APP_PUBLIC_URL=http://localhost:3000

# --- Transactional email (Resend) ---
# App notifications only (e.g. "certificate ready"); Supabase Auth sends its own auth
# emails. Server-only — used by the certificate worker. From resend.com → API Keys.
# If unset, app emails are skipped (logged) and never block issuance.
RESEND_API_KEY=
# Verified sender, e.g. "Nail Art Academy <noreply@yourdomain.com>". Domain must be
# verified in Resend before real sends succeed.
EMAIL_FROM=
